# Postiz — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# JWT secret (min 32 chars)
APP_JWT_TOKEN=changeme_jwt_secret_min_32_chars

# Database
DB_CREATE_DATABASE_NAME=postiz
DB_USER_NAME=postiz
DB_USER_PASS=changeme_db_password
